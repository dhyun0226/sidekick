# Supabase
# Local development should use the development Supabase project.
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_KEY=your-dev-anon-key
SUPABASE_SECRET_KEY=your-dev-service-role-key

# Toss Payments
# https://developers.tosspayments.com/
NUXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your-client-key
TOSS_SECRET_KEY=test_sk_your-secret-key
TOSS_WEBHOOK_SECRET=your-toss-webhook-secret

# Cron
CRON_SECRET=your-cron-secret

# Base URL
NUXT_PUBLIC_BASE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_URL=http://localhost:3000
